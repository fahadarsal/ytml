      ">
        <div style="text-align: center; color: #fff; padding: 40px; max-width: 800px;">
          <div style="
            font-size: 4em; margin-bottom: 20px;
            animation: popIn 0.5s cubic-bezier(0.34,1.56,0.64,1) both;
          ">🚀</div>
          <h2 style="font-size: 2.6em; margin: 0 0 16px; animation: fadeUp 0.7s 0.2s ease-out both;">
            Start building with RAG
          </h2>
          <p style="color: #888; font-size: 1.2em; margin: 0 0 32px; animation: fadeUp 0.7s 0.4s ease-out both;">
